# NoteLMs Mac Studio Express API
# Copy to server/.env and fill in. Loaded via: node --env-file=.env

# Must match Vercel NEXTAUTH_SECRET exactly (JWT bridge).
AUTH_SECRET=replace-with-same-secret-as-vercel-NEXTAUTH_SECRET

# Bind address. Production tunnel expects 3002 (shared Cloudflare tunnel with SocketHR).
PORT=3002
HOST=0.0.0.0

# Filesystem root for all user notes / profiles.
# Leave unset to auto-discover the Samsung USB volume under /Volumes
# (same idea as SocketHR's SOCKETHR_DATA_DIR) and use <volume>/notelms.
# NOTELMS_DATA_DIR="/Volumes/Samsung USB/notelms"

# LM Studio OpenAI-compatible local server (never expose publicly).
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=openai/gpt-oss-20b

# Local BERT inference service (zero-shot + fine-tuned). Never tunnel this.
BERT_SERVICE_URL=http://127.0.0.1:3003

# OpenAI — image OCR only (vision extracts raw text before classify/format).
# Put the key in server/.env on the Mac (never commit it; never expose via tunnel).
OPENAI_API_KEY=
# Optional override (default gpt-4o-mini).
# OPENAI_OCR_MODEL=gpt-4o-mini

# Comma-separated browser origins allowed by CORS.
ALLOWED_ORIGINS=https://notelms.com,https://www.notelms.com,http://localhost:3000,http://127.0.0.1:3000

# JWT claims (must match web/src/pages/api/mac-token.ts).
JWT_ISSUER=notelms-next
JWT_AUDIENCE=notelms-mac-api
