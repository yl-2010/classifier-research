{
  "name": "classifier-research",
  "private": true,
  "version": "0.1.0",
  "description": "NoteLMs — student notes classifier research + Mac Studio API",
  "scripts": {
    "dev": "npm run dev --prefix web",
    "build": "npm run build --prefix web",
    "start": "npm run start --prefix web",
    "server": "npm run start --prefix server",
    "server:dev": "npm run dev --prefix server",
    "tts": "./scripts/start-notelms-tts.sh",
    "verify:public-api": "curl -fsS https://api.notelms.com/health",
    "test:server": "npm test --prefix server",
    "bert:serve": ".venv/bin/python scripts/bert_serve.py",
    "bert:train": ".venv/bin/python scripts/train_bert.py",
    "bert:eval": ".venv/bin/python scripts/eval_bert.py"
  },
  "engines": {
    "node": ">=20"
  }
}
